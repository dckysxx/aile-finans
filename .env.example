# ---- Supabase (Project Settings → API) ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ---- Web Push bildirimleri ----
# VAPID anahtarlarını üretmek için:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BOxxxx...
VAPID_PRIVATE_KEY=xxxx...
VAPID_SUBJECT=mailto:seninmailin@ornek.com

# Sunucu tarafı bildirim gönderimi (Project Settings → API → service_role key)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Cron endpoint'ini korumak için rastgele bir gizli değer
CRON_SECRET=uzun-rastgele-bir-deger
